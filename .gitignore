# ignore python cached stuff
*.pyc
__pycache__/

# ignore log files
*.log

# don't commit secret key or db login info
.env

# package metadata
*.egg-info

# Don't commit CS50x/speller distribution code, it can be obtained from CS50
speller.zip
speller/

# files used during testing
speller_workspace/dictionary50.o
speller_workspace/dictionary_sanath.c
speller_workspace/dictionary50_original.c

# Ignore flask_session cookies
flask_session/

# ignore files generated by flask-assets library (bundles js and css together)
app/static/bundled
app/static/.webassets-cache